  "definitions": {
    "CreateUserRequest": {
      "type": "object",
      "properties": {
        "age": {
          "type": "integer",
          "description": "User age",
          "example": "25"
        },
        "email": {
          "type": "string",
          "description": "User email",
          "example": "vu@example.com"
        },
        "name": {
          "type": "string",
          "description": "User name",
          "example": "vu"
        },
