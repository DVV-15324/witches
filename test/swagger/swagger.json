        },
        "status": {
          "type": "integer"
        }
      }
    },
    "User": {
      "type": "object",
      "properties": {
        "age": {
          "type": "integer",
          "description": "User age",
          "example": "25",
          "minimum": 0,
          "maximum": 150
        },
        "email": {
          "type": "string",
          "description": "User email",
          "example": "vu@example.com"
        },
        "id": {
          "type": "integer",
          "description": "User ID",
          "example": "1"
        },
        "name": {
          "type": "string",
          "description": "User name",
          "example": "vu",
          "maxLength": 100
        }
      },
      "required": [
        "name",
        "email"
      ]
