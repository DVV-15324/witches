{
  "swagger": "2.0",
  "info": {
    "title": "My API",
    "version": "1.0"
  },
  "host": "localhost:8080",
  "basePath": "/api",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/v1/auth/login": {
      "post": {
        "summary": "User login",
        "description": "Authenticate user and return JWT token",
        "tags": [
          "auth"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Login credentials",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Login"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          }
        }
      }
    },
    "/v1/auth/register": {
      "post": {
        "summary": "User registration",
        "description": "Register a new user",
        "tags": [
          "auth"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "User registration data",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Register"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Registration successful",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          }
        }
      }
    },
    "/v1/user/get_user": {
      "post": {
        "summary": "Get user by ID",
        "description": "Get user details by user ID",
        "tags": [
          "user"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "User ID",
            "required": true,
            "schema": {
              "$ref": "#/definitions/"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User found",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          }
        },
        "security": [
          {
            "BearerAuth": null
          }
        ]
      }
    },
    "/v1/user/get_user_all": {
      "post": {
        "summary": "Get all users",
        "description": "Get list of all users",
        "tags": [
          "user"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Users list",
            "schema": {
              "$ref": "#/definitions/ResponseHandle"
            }
          }
        },
        "security": [
          {
            "BearerAuth": null
          }
        ]
      }
    }
  },
  "definitions": {
    "Login": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      }
    },
    "Register": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      }
    },
    "ResponseHandle": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        },
        "message": {
          "type": "string"
        },
        "status": {
          "type": "integer"
        },
        "timestamp": {
          "type": "string"
        }
      }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "description": "JWT Authorization header using the Bearer scheme. Example: 'Bearer {token}'",
      "name": "Authorization",
      "in": "header"
    }
  },
  "tags": [
    {
      "name": "v1",
      "description": "API Version 1"
    }
  ]
}